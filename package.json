{
  "name": "sldeditor",
  "version": "0.0.2",
  "description": "Lightweight in-browser React editor for electrical single-line diagrams (SLD).",
  "type": "module",
  "license": "MIT",
  "author": "NovaShang",
  "homepage": "https://github.com/NovaShang/sldeditor#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NovaShang/sldeditor.git"
  },
  "bugs": {
    "url": "https://github.com/NovaShang/sldeditor/issues"
  },
  "keywords": [
    "react",
    "electrical",
    "single-line-diagram",
    "sld",
    "schematic",
    "diagram",
    "editor",
    "electrical-engineering",
    "one-line-diagram",
    "power-system"
  ],
  "main": "./dist/sldeditor.cjs",
  "module": "./dist/sldeditor.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/sldeditor.js",
      "require": "./dist/sldeditor.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:lib": "tsc -p tsconfig.lib.json --emitDeclarationOnly && vite build --config vite.lib.config.ts",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.lib.json --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build:lib && changeset publish",
    "prepublishOnly": "npm run build:lib"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "tailwind-merge": "^2.6.0",
    "zustand": "^5.0.2"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.17.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "postcss": "^8.5.14",
    "postcss-prefix-selector": "^2.1.1",
    "prettier": "^3.4.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.19.0",
    "vite": "^6.0.7",
    "vite-plugin-dts": "^4.4.0",
    "vitest": "^2.1.8"
  }
}
