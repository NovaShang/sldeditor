{
  "version": "1",
  "meta": {
    "title": "220/35kV 双母线变电站（综合测试用例）",
    "description": "220kV 双母线 + 母联 + 1#主变 + 35kV 母线（多馈线 / 容性补偿 / 电抗器 / 电动机 / 电池储能 / 光伏并网 / 接地变 + NGR）",
    "author": "dev-fixture",
    "createdAt": "2026-05-07T00:00:00Z",
    "updatedAt": "2026-05-07T00:00:00Z"
  },

  "elements": [
    { "id": "GRID1", "kind": "grid-source", "name": "线路 L1（北郊变）" },
    { "id": "QS_L1",    "kind": "disconnector", "name": "L1-01" },
    { "id": "QF_L1",    "kind": "breaker",      "name": "L1-Q" },
    { "id": "QS_L1_I",  "kind": "disconnector", "name": "L1-1" },
    { "id": "QS_L1_II", "kind": "disconnector", "name": "L1-2", "state": { "open": true } },

    { "id": "GRID2", "kind": "grid-source", "name": "线路 L2（南郊变）" },
    { "id": "QS_L2",    "kind": "disconnector", "name": "L2-01" },
