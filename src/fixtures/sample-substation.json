{
  "version": "1",
  "meta": {
    "title": "110/35kV 单母线变电站（开发测试用例）",
    "description": "练手 fixture：进线 + 主变 + 35kV 母线 + 两条馈线 + 容性补偿。",
    "author": "dev-fixture",
    "createdAt": "2026-05-07T00:00:00Z",
    "updatedAt": "2026-05-07T00:00:00Z"
  },

  "elements": [
    { "id": "GRID", "kind": "grid-source", "name": "外部电网" },

    { "id": "QS01", "kind": "disconnector", "name": "01" },
    { "id": "QF01", "kind": "breaker",      "name": "进线开关" },
    { "id": "QS02", "kind": "disconnector", "name": "02" },
    { "id": "CT1",  "kind": "ct",           "name": "进线 CT" },

    { "id": "PT1",   "kind": "pt",          "name": "母线 PT" },

    { "id": "QS_T1", "kind": "disconnector", "name": "主变高压侧刀闸" },
    { "id": "QF_T1", "kind": "breaker",      "name": "主变高压侧开关" },
    {
      "id": "T1", "kind": "transformer-2w", "name": "1#主变",
      "note": "240MVA YNd11，2024-Q3 大修后投运",
      "params": { "S": 240, "ratio": "110/35" }
    },
    { "id": "GND_T1", "kind": "earth", "name": "T1 中性点接地" },

    { "id": "FBL1",   "kind": "arrester", "name": "母线避雷器" },
    { "id": "GND_FBL1", "kind": "earth" },

    { "id": "QS_F1", "kind": "disconnector", "name": "馈线 1 刀闸" },
    { "id": "QF_F1", "kind": "breaker",      "name": "馈线 1 开关" },
    { "id": "LD1",   "kind": "load",         "name": "馈线 1 (3MW)",
      "params": { "P": 3.0, "cosphi": 0.95 } },

    { "id": "QS_F2", "kind": "disconnector", "name": "馈线 2 刀闸", "state": { "open": true } },
    { "id": "QF_F2", "kind": "breaker",      "name": "馈线 2 开关", "state": { "open": true } },
    { "id": "LD2",   "kind": "load",         "name": "馈线 2 (备用)" },

    { "id": "QS_C1", "kind": "disconnector",   "name": "电容器组刀闸" },
    { "id": "QF_C1", "kind": "breaker",        "name": "电容器组开关" },
    { "id": "C1",    "kind": "shunt-capacitor", "name": "无功补偿 C1",
      "params": { "Q": 6 } },
    { "id": "GND_C1", "kind": "earth" }
  ],

  "buses": [
    {
      "id": "B1", "name": "110kV-I", "params": { "Un": 110 },
      "layout": { "at": [400, 320], "span": 600 }
    },
    {
      "id": "B2", "name": "35kV", "params": { "Un": 35 },
      "layout": { "at": [400, 620], "span": 600 }
    }
  ],

  "wires": [
    { "id": "w_grid_qs01",      "ends": ["GRID.t_bottom", "QS01.t1"] },
    { "id": "w_qs01_qf01",      "ends": ["QS01.t2", "QF01.t1"] },
    { "id": "w_qf01_qs02",      "ends": ["QF01.t2", "QS02.t1"] },
    { "id": "w_qs02_ct1",       "ends": ["QS02.t2", "CT1.t1"] },
    { "id": "w_b1_ct1",         "ends": ["B1", "CT1.t2"] },
    { "id": "w_b1_qs_t1",       "ends": ["B1", "QS_T1.t1"] },
    { "id": "w_b1_pt1",         "ends": ["B1", "PT1.t1"] },

    { "id": "w_qs_t1_qf_t1",    "ends": ["QS_T1.t2", "QF_T1.t1"] },
    { "id": "w_qf_t1_t1",       "ends": ["QF_T1.t2", "T1.t1"] },
    { "id": "w_t1_gnd",         "ends": ["T1.t2", "GND_T1.t1"] },

    { "id": "w_fbl1_gnd",       "ends": ["FBL1.t2", "GND_FBL1.t1"] },

    { "id": "w_b2_t1",          "ends": ["B2", "T1.t2"] },
    { "id": "w_b2_fbl1",        "ends": ["B2", "FBL1.t1"] },
    { "id": "w_b2_qs_f1",       "ends": ["B2", "QS_F1.t1"] },
    { "id": "w_b2_qs_f2",       "ends": ["B2", "QS_F2.t1"] },
    { "id": "w_b2_qs_c1",       "ends": ["B2", "QS_C1.t1"] },

    { "id": "w_qs_f1_qf_f1",    "ends": ["QS_F1.t2", "QF_F1.t1"] },
    { "id": "w_qf_f1_ld1",      "ends": ["QF_F1.t2", "LD1.t_top"] },
    { "id": "w_qs_f2_qf_f2",    "ends": ["QS_F2.t2", "QF_F2.t1"] },
    { "id": "w_qf_f2_ld2",      "ends": ["QF_F2.t2", "LD2.t_top"] },

    { "id": "w_qs_c1_qf_c1",    "ends": ["QS_C1.t2", "QF_C1.t1"] },
    { "id": "w_qf_c1_c1",       "ends": ["QF_C1.t2", "C1.t1"] },
    { "id": "w_c1_gnd",         "ends": ["C1.t_bottom", "GND_C1.t1"] }
  ],

  "layout": {
    "GRID":   { "at": [200,  20] },
    "QS01":   { "at": [200,  80] },
    "QF01":   { "at": [200, 140] },
    "QS02":   { "at": [200, 200] },
    "CT1":    { "at": [200, 260] },
    "PT1":    { "at": [600, 380] },

    "QS_T1":  { "at": [200, 380] },
    "QF_T1":  { "at": [200, 440] },
    "T1":     { "at": [200, 520] },
    "GND_T1": { "at": [280, 520] }
  }
}
